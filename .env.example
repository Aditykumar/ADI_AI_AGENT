# ╔══════════════════════════════════════════════════════════════════════╗
# ║          AI Testing Agent — Environment Config                      ║
# ║                                                                     ║
# ║  Pick ONE provider below and set AI_PROVIDER= to its name          ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ┌─────────────────────────────────────────────────────────────────────┐
# │  AI_PROVIDER options:                                               │
# │                                                                     │
# │  "ollama"  → 100% FREE, runs locally (LLaMA on your machine)       │
# │  "groq"    → FREE cloud tier (6000 req/day, llama3/mixtral, fast)  │
# │  "claude"  → Anthropic Claude API (paid, best quality)             │
# │  "openai"  → OpenAI GPT API (paid)                                 │
# └─────────────────────────────────────────────────────────────────────┘

AI_PROVIDER=ollama

# ══════════════════════════════════════════════════════════════════════
# OPTION 1 — Ollama  (100% FREE — runs on your laptop)
# ══════════════════════════════════════════════════════════════════════
# Start:  ollama serve
# Models: ollama pull llama3.2    (2 GB, balanced)
#         ollama pull llama3.2:1b (1.3 GB, fastest)
#         ollama pull mistral     (4 GB, good quality)
#         ollama pull phi3        (2 GB, fast, smart)
#         ollama pull gemma2:2b   (1.6 GB, tiny but capable)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ══════════════════════════════════════════════════════════════════════
# OPTION 2 — Groq  (FREE cloud tier — no credit card needed)
# ══════════════════════════════════════════════════════════════════════
# Sign up free: https://console.groq.com
# Free limits:  6,000 requests/day, 500,000 tokens/day
# Models:       llama-3.3-70b-versatile  (best free quality)
#               llama-3.1-8b-instant     (fastest)
#               mixtral-8x7b-32768       (large context)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ══════════════════════════════════════════════════════════════════════
# OPTION 3 — Claude  (Anthropic — best reasoning, paid)
# ══════════════════════════════════════════════════════════════════════
# Get key: https://console.anthropic.com
# Models:  claude-sonnet-4-6          (best quality, recommended)
#          claude-haiku-4-5-20251001  (fastest + cheapest)
#          claude-opus-4-6            (most capable, expensive)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ══════════════════════════════════════════════════════════════════════
# OPTION 4 — OpenAI  (paid)
# ══════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ══════════════════════════════════════════════════════════════════════
# Target Site
# ══════════════════════════════════════════════════════════════════════
TARGET_URL=https://example.com
API_BASE_URL=https://example.com
API_KEY=

# ══════════════════════════════════════════════════════════════════════
# SSO / Login Credentials (optional — for auth flow tests)
# ══════════════════════════════════════════════════════════════════════
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_TOKEN=
AUTH_LOGIN_URL=
AUTH_TOKEN_ENDPOINT=

# ══════════════════════════════════════════════════════════════════════
# Performance & Output
# ══════════════════════════════════════════════════════════════════════
LIGHTHOUSE_TIMEOUT=60000
REPORTS_DIR=./reports
SCREENSHOTS_DIR=./screenshots
DEBUG=false
